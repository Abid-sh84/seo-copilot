PORT=5000
NODE_ENV=development

# MongoDB Atlas (replace with your connection string)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/seocopilot?retryWrites=true&w=majority

# Google Gemini API Key
# Get from: console.cloud.google.com → APIs → Gemini API → Enable → Create Key
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret (use a strong random string, min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
